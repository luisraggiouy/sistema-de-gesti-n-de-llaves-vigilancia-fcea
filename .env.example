# Configuración del Sistema de Gestión de Llaves FCEA

# Tipo de dispositivo - determina qué interfaz mostrar automáticamente
# Valores posibles: "monitor", "terminal", "auto"
# - "monitor": Siempre muestra el Monitor de Vigilancia
# - "terminal": Siempre muestra la Terminal de Usuario  
# - "auto": Detecta automáticamente basado en la URL o configuración
VITE_DEVICE_TYPE=auto

# Modo de producción - oculta botones de navegación entre interfaces
# Valores: "true" o "false"
VITE_PRODUCTION_MODE=false

# ID único del dispositivo (opcional) - para identificar dispositivos específicos
# Útil cuando se tienen múltiples terminales
VITE_DEVICE_ID=

# Configuración de PocketBase
VITE_POCKETBASE_URL=http://localhost:8090

# Configuración de red
VITE_NETWORK_CHECK_INTERVAL=3000